{
  "name": "steam-player-tracker",
  "version": "1.3.0",
  "description": "Track Steam game concurrent player counts and export to CSV/Google Sheets",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "calculate-daily-averages": "node dist/tools/calculateAllDailyAverages.js",
    "sync-google-sheets": "node dist/tools/syncGoogleSheets.js",
    "generate-charts": "node dist/tools/generateCharts.js",
    "kill": "pwsh -ExecutionPolicy Bypass -File Scripts/Kill-SteamTracker.ps1",
    "setup": "npm install && npm run build",
    "release": "node scripts/release.js",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "prerelease": "npm run test:ci",
    "test:ci": "npm run typecheck && npm run lint",
    "prepare-release": "npm run clean && npm run build && npm run test:ci"
  },
  "keywords": [
    "steam",
    "player-tracking",
    "csv",
    "google-sheets"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "chart.js": "^4.5.0",
    "chartjs-node-canvas": "^5.0.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.6.1",
    "googleapis": "^126.0.0",
    "node-cron": "^3.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/node-cron": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
