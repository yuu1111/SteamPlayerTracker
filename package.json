{
	"name": "steam-player-tracker",
	"version": "1.3.0",
	"type": "module",
	"description": "Track Steam game concurrent player counts with SQLite storage and optional Google Sheets sync",
	"main": "dist/main",
	"scripts": {
		"build": "bun scripts/build.ts",
		"start": "bun dist/main.js",
		"dev": "bun --watch src/main.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write --unsafe .",
		"kill": "dev-clean --yes",
		"setup": "bun install && bun run build",
		"release": "bun scripts/release.ts",
		"release:minor": "bun scripts/release.ts minor",
		"release:major": "bun scripts/release.ts major",
		"import-csv": "bun src/tools/importCsv.ts",
		"export-csv": "bun src/tools/exportCsv.ts",
		"generate-charts": "bun src/tools/generateCharts.ts",
		"test": "STEAM_APP_ID=730 DB_PATH=data/test.db bun test"
	},
	"keywords": [
		"steam",
		"player-tracking",
		"sqlite",
		"google-sheets"
	],
	"author": "yuu1111",
	"license": "MIT",
	"dependencies": {
		"chart.js": "^4.5.1",
		"chartjs-node-canvas": "^5.0.0",
		"dayjs": "^1.11.20",
		"dev-clean": "^1.0.8",
		"googleapis": "^171.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.11",
		"@yuu1111/biome-config": "^1.0.3",
		"@yuu1111/tsconfig": "^1.0.2",
		"typescript": "^6.0.2"
	}
}
