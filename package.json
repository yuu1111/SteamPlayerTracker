{
	"name": "steam-player-tracker",
	"version": "1.3.0",
	"type": "module",
	"description": "Track Steam game concurrent player counts and export to CSV/Google Sheets",
	"main": "dist/main",
	"scripts": {
		"build": "bun build src/index.ts src/tools/calculateAllDailyAverages.ts src/tools/syncGoogleSheets.ts src/tools/generateCharts.ts --outdir dist --target node --format esm --splitting",
		"start": "bun dist/main.js",
		"dev": "bun --watch src/index.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write --unsafe .",
		"calculate-daily-averages": "bun dist/tools/calculateAllDailyAverages.js",
		"sync-google-sheets": "bun dist/tools/syncGoogleSheets.js",
		"generate-charts": "bun dist/tools/generateCharts.js",
		"kill": "dev-clean --yes",
		"setup": "bun install && bun run build",
		"release": "node scripts/release.cjs",
		"release:minor": "node scripts/release.cjs minor",
		"release:major": "node scripts/release.cjs major",
		"prerelease": "bun run test:ci",
		"test:ci": "bun run typecheck && bun run lint",
		"prepare-release": "bun run clean && bun run build && bun run test:ci"
	},
	"keywords": [
		"steam",
		"player-tracking",
		"csv",
		"google-sheets"
	],
	"author": "yuu1111",
	"license": "MIT",
	"dependencies": {
		"axios": "^1.13.6",
		"chart.js": "^4.5.1",
		"chartjs-node-canvas": "^5.0.0",
		"date-fns": "^4.1.0",
		"dayjs": "^1.11.20",
		"dev-clean": "^1.0.6",
		"googleapis": "^171.4.0",
		"node-cron": "^4.2.1",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/node": "^25.5.0",
		"@yuu1111/biome-config": "^1.0.3",
		"@yuu1111/tsconfig": "^1.0.2",
		"typescript": "^5.9.3"
	}
}
